---
export interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;
---

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="text-center mb-12">
    <h2 class="section-heading mb-4">Frequently Asked Questions</h2>
    <p class="section-sub mx-auto">Everything you need to know about our address generator.</p>
  </div>

  <div class="space-y-3">
    {faqs.map((faq, i) => (
      <details class="group glass-card rounded-xl overflow-hidden transition-all duration-200 [&[open]]:shadow-xl [&[open]]:shadow-brand-500/5">
        <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none hover:bg-gray-50/50 transition-colors">
          <span class="font-medium text-gray-900 pr-4">{faq.question}</span>
          <svg class="w-5 h-5 text-gray-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-4 text-sm text-gray-600 leading-relaxed">
          {faq.answer}
        </div>
      </details>
    ))}
  </div>
</section>

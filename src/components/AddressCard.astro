---
import firstNames from '../data/firstNames.json';
import lastNames from '../data/lastNames.json';
import streets from '../data/streets.json';
import states from '../data/states.json';
import cities from '../data/cities.json';
import zipcodes from '../data/zipcodes.json';

export interface Props {
  state?: string;
  city?: string;
  zip?: string;
}

const { state, city, zip } = Astro.props;

const dataJson = JSON.stringify({ firstNames, lastNames, streets, states, cities, zipcodes });

const script = `(function(){
var DATA = ${dataJson};
window.__AD = DATA;
function pick(a){return a[Math.floor(Math.random()*a.length)]}
var AC={CA:"213",TX:"713",NY:"212",FL:"305",IL:"312",PA:"215",OH:"614",GA:"404",NC:"704",MI:"313",NJ:"201",VA:"703",WA:"206",AZ:"602",MA:"617",TN:"615",IN:"317",MO:"314",MD:"301",WI:"414",CO:"303",MN:"612",SC:"803",AL:"205",LA:"504",KY:"502",OR:"503",OK:"405",CT:"203",IA:"515",MS:"601",AR:"501",KS:"913",UT:"801",NV:"702",NM:"505",WV:"304",NE:"402",ID:"208",HI:"808",ME:"207",NH:"603",RI:"401",MT:"406",DE:"302",SD:"605",ND:"701",AK:"907",VT:"802",WY:"307"};
function gp(a){var c=AC[a]||"555";return "("+c+")"+String(Math.floor(Math.random()*900)+100)+"-"+String(Math.floor(Math.random()*9000)+1000)}
function gsa(n){var s=DATA.states.find(function(s){return s.name===n});return s?s.abbr:""}
var DM=["gmail.com","yahoo.com","outlook.com","hotmail.com","aol.com","icloud.com","protonmail.com"];
function ge(fn,ln){return fn.toLowerCase()+"."+ln.toLowerCase()+Math.floor(Math.random()*999)+"@"+pick(DM)}
function gen(){var card=document.querySelector("[data-address-card]"),SF=card?card.getAttribute("data-state")||"":null,CF=card?card.getAttribute("data-city")||"":null,ZF=card?card.getAttribute("data-zip")||"":null;var fn=pick(DATA.firstNames),ln=pick(DATA.lastNames),g=Math.random()>0.5?"Male":"Female",sn=String(Math.floor(Math.random()*9999)+1),s=pick(DATA.streets);var cs=DATA.cities,zs=DATA.zipcodes;if(SF){cs=cs.filter(function(c){return c.state===SF});zs=zs.filter(function(z){return z.state===SF})}if(CF){cs=cs.filter(function(c){return c.city===CF});zs=zs.filter(function(z){return z.city===CF})}if(ZF){zs=zs.filter(function(z){return z.zip===ZF})}if(cs.length===0){cs=DATA.cities}if(zs.length===0){zs=DATA.zipcodes}var cd=pick(cs);var mz=zs.filter(function(z){return z.city===cd.city&&z.state===cd.state});var zd=mz.length>0?pick(mz):(function(){var f=zs.filter(function(z){return z.state===cd.state});return f.length>0?pick(f):pick(zs)})();var sa=gsa(cd.state);return{name:fn+" "+ln,gender:g,street:sn+" "+s,city:cd.city,state:cd.state,zip:zd.zip,phone:gp(sa),email:ge(fn,ln)}}
function rn(a){document.querySelectorAll("[data-field]").forEach(function(e){e.textContent=a[e.getAttribute("data-field")]});var b=document.querySelector("[data-copy]");if(b){b.setAttribute("data-address",a.name+", "+a.street+", "+a.city+", "+a.state+" "+a.zip+", Email: "+a.email)}}
document.addEventListener("DOMContentLoaded",function(){rn(gen())});
document.addEventListener("click",function(e){var b=e.target.closest("[data-regenerate]");if(b){rn(gen())}});
document.addEventListener("click",function(e){var b=e.target.closest("[data-copy]");if(!b)return;var t=b.getAttribute("data-address")||"";navigator.clipboard.writeText(t).then(function(){var d=document.getElementById("toast");if(!d){d=document.createElement("div");d.id="toast";d.className="fixed bottom-24 left-1/2 -translate-x-1/2 z-50 bg-gray-900 text-white text-sm font-medium px-5 py-3 rounded-xl shadow-2xl animate-slide-up";document.body.appendChild(d)}d.textContent="Copied to clipboard!";setTimeout(function(){d.style.animation="toastOut 0.3s ease-out forwards";setTimeout(function(){if(d&&d.parentNode)d.parentNode.removeChild(d)},300)},2000)})});
})();`;

---

<div class="glass-card rounded-2xl p-6 sm:p-8 fade-in" data-address-card data-state={state} data-city={city} data-zip={zip}>
  <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
    <div class="w-10 h-10 rounded-xl gradient-bg flex items-center justify-center shadow-lg shadow-brand-500/20">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
    </div>
    <div>
      <h3 class="font-semibold text-gray-900">Generated Address</h3>
      <p class="text-xs text-gray-400">Click copy to use</p>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Name</span>
      <p class="mt-1 font-semibold text-gray-900" data-field="name"></p>
    </div>
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Gender</span>
      <p class="mt-1 font-semibold text-gray-900" data-field="gender"></p>
    </div>
    <div class="col-span-2">
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Street Address</span>
      <p class="mt-1 font-semibold text-gray-900" data-field="street"></p>
    </div>
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">City</span>
      <p class="mt-1 font-semibold text-gray-900" data-field="city"></p>
    </div>
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">State</span>
      <p class="mt-1 font-semibold text-gray-900" data-field="state"></p>
    </div>
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">ZIP Code</span>
      <p class="mt-1 font-mono font-semibold text-gray-900" data-field="zip"></p>
    </div>
    <div>
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Phone</span>
      <p class="mt-1 font-mono font-semibold text-gray-900" data-field="phone"></p>
    </div>
    <div class="col-span-2">
      <span class="text-xs font-medium uppercase tracking-wider text-gray-400">Email</span>
      <p class="mt-1 font-mono text-sm text-gray-900" data-field="email"></p>
    </div>
  </div>

  <div class="mt-6 pt-4 border-t border-gray-100 flex flex-col sm:flex-row gap-3">
    <button data-copy class="flex-1 btn-primary text-sm sm:text-base px-5 py-3 sm:py-2.5 min-h-[48px]">
      <svg class="w-4 h-4 sm:w-5 sm:h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
      </svg>
      <span class="whitespace-nowrap">Copy Address</span>
    </button>
    <button data-regenerate class="flex-1 btn-secondary text-sm sm:text-base px-5 py-3 sm:py-2.5 min-h-[48px]">
      <svg class="w-4 h-4 sm:w-5 sm:h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      <span class="whitespace-nowrap">Generate Again</span>
    </button>
  </div>
</div>

<script is:inline set:html={script}></script>
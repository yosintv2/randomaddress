---
import Layout from '../layouts/Layout.astro';
import AddressCard from '../components/AddressCard.astro';
import ToolCard from '../components/ToolCard.astro';
import SitemapLinks from '../components/SitemapLinks.astro';
import FAQs from '../components/FAQs.astro';
import { buildTitle, getWebApplicationSchema, getFAQSchema, getOrganizationSchema, getWebPageSchema, SITE_URL } from '../lib/seo';
import { getCities, getZipcodes } from '../lib/generator';
import statesData from '../data/states.json';
const cityCount = new Set(getCities().map(c => c.city)).size;
const zipCount = getZipcodes().length;
const stateCount = statesData.length;
const faqs = [
  { question: 'What is a random US address generator?', answer: 'A random US address generator is a free online tool that creates random but realistic US addresses for testing, development, and educational purposes. It generates complete addresses including street names, cities, states, ZIP codes, and phone numbers.' },
  { question: 'Is this free to use?', answer: 'Yes, Random US Address Generator is completely free to use. No registration or account is required.' },
  { question: 'Are these real addresses?', answer: 'No, these addresses are randomly generated and are not real. They are created using realistic datasets and are intended for testing purposes only.' },
  { question: 'Can I use these addresses for shipping?', answer: 'No, these are randomly generated addresses and should not be used for shipping, legal documents, or any official purposes.' },
  { question: 'How many states do you support?', answer: 'We support all 50 US states, plus Washington DC and Puerto Rico.' },
  { question: 'Do you generate phone numbers too?', answer: 'Yes, each generated address includes a realistic phone number with a valid area code for the corresponding state.' },
  { question: 'How does the address generator work?', answer: 'Our generator combines random street names, numbers, cities, states, and ZIP codes from our datasets to create realistic-looking addresses.' },
  { question: 'Can I generate multiple addresses?', answer: 'Yes, you can generate as many addresses as you want by clicking the "Generate Again" button.' },
  { question: 'Do you have state-specific addresses?', answer: 'Yes, you can generate addresses for specific states like California, Texas, New York, and more.' },
  { question: 'What are random addresses used for?', answer: 'Random addresses are commonly used for software testing, form validation, demo data, educational purposes, and protecting privacy.' },
];
---

<Layout title={buildTitle('Random US Address Generator - Free Random US Address Generator')} keywords="random US address generator, free address generator, random address, US address generator, test address generator" canonical={SITE_URL}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getWebPageSchema(title, description, canonical || SITE_URL))} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getWebApplicationSchema())} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getOrganizationSchema())} />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 gradient-bg-light"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-brand-100/40 via-transparent to-transparent"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-accent-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-brand-400/10 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="text-center max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-100 text-brand-700 text-sm font-medium mb-6 animate-float">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Free • No Registration • 50 States
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
          Generate Random<br/>
          <span class="gradient-text">US Addresses</span> Instantly
        </h1>
        <p class="text-lg sm:text-xl text-gray-500 max-w-2xl mx-auto mb-10 leading-relaxed">
          Generate free random US addresses with names, cities, states, ZIP codes, and phone numbers. 
          Built for developers, testers, and professionals.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="#generator" class="btn-primary text-base px-8 py-3.5 shadow-xl shadow-brand-500/25 animate-glow">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Generate Address Now
          </a>
          <a href="/all-tools/" class="btn-secondary text-base px-8 py-3.5">
            Explore All Tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="relative -mt-8 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="glass-card rounded-2xl p-6 sm:p-8 grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      {[
        { number: String(stateCount), label: 'US States', desc: 'All 50 states supported' },
        { number: `${cityCount}+`, label: 'Cities', desc: 'Major US cities included' },
        { number: `${zipCount}+`, label: 'ZIP Codes', desc: 'Realistic ZIP coverage' },
        { number: 'Free', label: 'To Use', desc: 'No registration needed' },
      ].map(stat => (
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-bold gradient-text">{stat.number}</div>
          <div class="text-sm font-semibold text-gray-900 mt-1">{stat.label}</div>
          <div class="text-xs text-gray-400 mt-0.5">{stat.desc}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Generator -->
  <section id="generator" class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <div class="text-center mb-10">
      <h2 class="section-heading mb-4">Try It Now</h2>
      <p class="section-sub mx-auto">Click generate to create a random US address with full details.</p>
    </div>
    <AddressCard />
  </section>

  <!-- Sample Addresses -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="section-heading mb-4">Sample Random Addresses</h2>
      <p class="section-sub mx-auto">Generate fresh random US addresses with one click. Each address includes name, street, city, state, ZIP, phone, and email.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4" id="sample-addresses">
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-4 text-sm">
        <div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        </div>
        <div class="space-y-1 text-gray-600">
          <div class="h-3 w-24 bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-full bg-gray-200 rounded animate-pulse"></div>
          <div class="h-3 w-32 bg-gray-200 rounded animate-pulse"></div>
        </div>
      </div>
    </div>
    <div class="text-center mt-8">
      <button data-regenerate class="btn-primary text-sm px-6 py-2.5 min-h-[48px]">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        Refresh Addresses
      </button>
    </div>
    <script is:inline>
    (function () {
      function renderSample(addresses) {
        var c = document.getElementById("sample-addresses");
        if (!c) return;
        var html = "";
        addresses.forEach(function (a) {
          html += '<div class="glass-card rounded-xl p-4 text-sm"><div class="w-8 h-8 rounded-lg gradient-bg flex items-center justify-center mb-3"><svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></div><div class="space-y-1 text-gray-600"><div class="font-semibold text-gray-900 text-xs">' + a.name + '</div><div class="text-xs">' + a.street + '</div><div class="text-xs">' + a.city + ", " + a.state + " " + a.zip + '</div><div class="text-xs text-gray-400">' + a.phone + " | " + a.email + '</div></div></div>';
        });
        c.innerHTML = html;
      }

      function fetchSamples() {
        var fetches = [];
        for (var i = 0; i < 8; i++) {
          fetches.push(fetch("/api/address.json").then(function (r) { return r.json(); }));
        }
        Promise.all(fetches).then(renderSample).catch(function () {});
      }

      document.addEventListener("DOMContentLoaded", fetchSamples);
      document.addEventListener("click", function (e) { if (e.target.closest("[data-regenerate]")) { fetchSamples(); } });
    })();
    </script>
  </section>

  <!-- Features -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="section-heading mb-4">Why Choose Our Generator?</h2>
      <p class="section-sub mx-auto">Everything you need for generating realistic US test data.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[
        { title: '100% Free', desc: 'No hidden costs, no registration. Unlimited address generation at zero cost.', color: 'from-emerald-500 to-teal-500' },
        { title: '50 States', desc: 'Complete coverage of all 50 US states with accurate city and ZIP data.', color: 'from-blue-500 to-indigo-500' },
        { title: 'Phone Numbers', desc: 'Every address includes a realistic phone number with valid area codes.', color: 'from-violet-500 to-purple-500' },
        { title: 'Realistic Data', desc: 'Our datasets use real street names, cities, and ZIP code patterns for authenticity.', color: 'from-orange-500 to-amber-500' },
        { title: 'Mobile Friendly', desc: 'Works perfectly on all devices. Generate addresses from your phone or tablet.', color: 'from-rose-500 to-pink-500' },
        { title: 'Instant Copy', desc: 'Copy any generated address to your clipboard with a single click.', color: 'from-cyan-500 to-teal-500' },
      ].map(f => (
        <div class="glass-card rounded-2xl p-6 card-hover">
          <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${f.color} flex items-center justify-center mb-4 shadow-lg`}>
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">{f.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Tools -->
  <section class="gradient-bg-light py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="section-heading mb-4">Explore All Tools</h2>
        <p class="section-sub mx-auto">From address generators to name generators — we have every tool you need.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        <ToolCard href="/random-address-generator/" title="Random US Address Generator" description="Generate random US addresses with complete details including street, city, ZIP, and phone." />
        <ToolCard href="/us-address-generator/" title="US Address Generator" description="Generate random US addresses with names, street, city, state, ZIP, phone, and email." />
        <ToolCard href="/random-person-generator/" title="Random Person Generator" description="Generate random people with names, age, address, phone, email, and username." />
        <ToolCard href="/phone-number-generator/" title="Phone Number Generator" description="Generate random US phone numbers with realistic area codes." />
        <ToolCard href="/street-address-generator/" title="Street Address Generator" description="Generate random street addresses with realistic street names." />
        <ToolCard href="/name-generator/" title="Name Generator" description="Generate random first and last names for US residents." />
        <ToolCard href="/username-generator/" title="Username Generator" description="Generate random usernames for testing and online profiles." />
        <ToolCard href="/company-name-generator/" title="Company Name Generator" description="Generate random company and business names." />
        <ToolCard href="/email-generator/" title="Email Generator" description="Generate random email addresses for testing." />
      </div>
    </div>
  </section>

  <SitemapLinks />

  <FAQs faqs={faqs} />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import { buildTitle } from '../lib/seo';
---

<Layout title={buildTitle('All Tools - Random US Address Generator Tools')}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12 fade-in">
      <h1 class="section-heading gradient-text mb-4">All Generator Tools</h1>
      <p class="section-sub mx-auto">Choose from our complete collection of free random data generation tools.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      <ToolCard href="/random-address-generator/" title="Random Address Generator" description="Generate random US addresses with complete details." />
      <ToolCard href="/test-address-generator/" title="Test Address Generator" description="Create test addresses for software development." />
      <ToolCard href="/random-person-generator/" title="Random Person Generator" description="Generate random people profiles." />
      <ToolCard href="/phone-number-generator/" title="Phone Number Generator" description="Generate random US phone numbers." />
      <ToolCard href="/street-address-generator/" title="Street Address Generator" description="Generate random street addresses." />
      <ToolCard href="/name-generator/" title="Name Generator" description="Generate random first and last names." />
      <ToolCard href="/username-generator/" title="Username Generator" description="Generate random usernames." />
      <ToolCard href="/company-name-generator/" title="Company Name Generator" description="Generate random company names." />
      <ToolCard href="/fake-email-generator/" title="Email Generator" description="Generate random email addresses." />
      <ToolCard href="/random-state-generator/" title="Random State Generator" description="Generate addresses from random states." />
      <ToolCard href="/random-city-generator/" title="Random City Generator" description="Generate addresses from random cities." />
      <ToolCard href="/us-address/" title="US Address Generator" description="Generate complete US addresses." />
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildTitle, SITE_URL } from '../lib/seo';
const description = 'Browse all free random data generator tools including address generator, person generator, phone number generator, name generator, and more.';
const canonical = `${SITE_URL}/all-tools/`;
---

<Layout title={buildTitle('All Tools - Random US Address Generator Tools')} description={description} canonical={canonical}>
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'All Tools', url: '/all-tools/' },
  ]} />
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12 fade-in">
      <h1 class="section-heading gradient-text mb-4">All Generator Tools</h1>
      <p class="section-sub mx-auto">Choose from our complete collection of free random data generation tools.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      <ToolCard href="/random-address-generator/" title="Random US Address Generator" description="Generate random US addresses with complete details." />
      <ToolCard href="/us-address-generator/" title="US Address Generator" description="Generate random US addresses for testing and development." />
      <ToolCard href="/random-person-generator/" title="Random Person Generator" description="Generate random people profiles." />
      <ToolCard href="/phone-number-generator/" title="Phone Number Generator" description="Generate random US phone numbers." />
      <ToolCard href="/street-address-generator/" title="Street Address Generator" description="Generate random street addresses." />
      <ToolCard href="/name-generator/" title="Name Generator" description="Generate random first and last names." />
      <ToolCard href="/username-generator/" title="Username Generator" description="Generate random usernames." />
      <ToolCard href="/company-name-generator/" title="Company Name Generator" description="Generate random company names." />
      <ToolCard href="/email-generator/" title="Email Generator" description="Generate random email addresses." />
      <ToolCard href="/random-state-generator/" title="Random US State Address Generator" description="Generate random US state addresses for testing." />
      <ToolCard href="/random-city-generator/" title="Random US City Address Generator" description="Generate random US city addresses for testing." />
      <ToolCard href="/us-address/" title="US Address Generator" description="Generate complete US addresses." />
      <ToolCard href="/ip-address-generator/" title="US IP Address Generator" description="Generate 200 random US IP addresses." />
    </div>
  </section>
</Layout>

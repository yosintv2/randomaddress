---
import Layout from '../../layouts/Layout.astro';
import { getCounties, getStates } from '../../lib/generator';
import { buildTitle, slugify } from '../../lib/seo';

const allCounties = getCounties();
const stateCountyMap = new Map<string, { name: string; state: string }[]>();
for (const c of allCounties) {
  if (!stateCountyMap.has(c.state)) stateCountyMap.set(c.state, []);
  stateCountyMap.get(c.state)!.push(c);
}
const sortedStates = [...stateCountyMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const totalCounties = allCounties.length;
---

<Layout title={buildTitle('All US Counties - County Address Generators')}>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-2">All US Counties ({totalCounties})</h1>
    <p class="text-gray-600 mb-8">Browse all US counties. Select a county to generate random addresses for that county.</p>

    {sortedStates.map(([state, counties]) => (
      <div class="mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3 flex items-center gap-2">
          <span class="w-1 h-5 rounded-full bg-brand-500"></span>
          {state} ({counties.length})
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">
          {counties.map(c => (
            <a href={`/${slugify(state)}/${slugify(c.name)}-county/`} class="bg-white p-3 rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-sm transition text-sm">
              <span class="font-medium text-gray-900">{c.name} County</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>

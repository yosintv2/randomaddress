---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import ToolCard from '../components/ToolCard.astro';
import FAQs from '../components/FAQs.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildTitle, SITE_URL, getFAQSchema, getWebPageSchema } from '../lib/seo';
const title = buildTitle('US Random Person Generator - Generate Random US People');
const description = 'Generate random people with complete details including name, age, address, phone number, email, and username.';
const keywords = 'random person generator, person profile generator, random identity, test data generator, random profile, fake person generator, random user generator, test user profile, identity generator, random people';
const canonical = `${SITE_URL}/random-person-generator/`;
const faqs = [
  { question: 'What is a random person generator?', answer: 'A random person generator creates complete fictional profiles with name, age, gender, street address, city, state, ZIP, phone, email, and username for testing and development.' },
  { question: 'Are these real people?', answer: 'No, all profiles are randomly generated and completely fictional. No real personal data is used.' },
  { question: 'What information is included?', answer: 'Each profile includes name, gender, age, street address, city, state, ZIP code, phone number, email address, and username.' },
  { question: 'Can I use these for testing?', answer: 'Yes, these profiles are perfect for testing user registration, populating demo databases, and load testing with realistic data.' },
  { question: 'Is this tool free?', answer: 'Yes, the random person generator is completely free to use with no registration required.' },
  { question: 'How is the data generated?', answer: 'Our generator combines random names, addresses, phone numbers, emails, and usernames from realistic datasets to create complete person profiles.' },
];
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getWebPageSchema(title, description, canonical))} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'US Random Person Generator', url: '/random-person-generator/' },
  ]} />
  <GeneratorTool
    title="US Random Person Generator"
    description={description}
  >
    <div class="glass-card rounded-2xl p-6 sm:p-8 fade-in">
      <div class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
        {['name','gender','age','username','street','city','state','zip','phone','email'].map(f => {
          const isSpan = ['street','email'].includes(f);
          const labels: Record<string, string> = { name:'Name', gender:'Gender', age:'Age', username:'Username', street:'Street', city:'City', state:'State', zip:'ZIP', phone:'Phone', email:'Email' };
          return (
            <div class={isSpan ? 'col-span-2' : ''}>
              <span class="text-xs font-medium uppercase tracking-wider text-gray-400">{labels[f]}</span>
              <p class="mt-1 font-semibold text-gray-900" data-pf={f}></p>
            </div>
          );
        })}
      </div>
      <div class="mt-6 pt-4 border-t border-gray-100 flex flex-col sm:flex-row gap-3">
        <button data-copy-person class="flex-1 btn-primary text-sm px-4 py-2.5 min-h-[48px]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
          </svg>
          Copy Profile
        </button>
      </div>
    </div>
  </GeneratorTool>
  <script is:inline>
  (function () {
    function showToast(msg) {
      var d = document.getElementById("toast");
      if (!d) {
        d = document.createElement("div");
        d.id = "toast";
        d.className = "fixed bottom-24 left-1/2 -translate-x-1/2 z-50 bg-gray-900 text-white text-sm font-medium px-5 py-3 rounded-xl shadow-2xl animate-slide-up";
        document.body.appendChild(d);
      }
      d.textContent = msg;
      setTimeout(function () {
        d.style.animation = "toastOut 0.3s ease-out forwards";
        setTimeout(function () { if (d && d.parentNode) d.parentNode.removeChild(d); }, 300);
      }, 2000);
    }

    function render() {
      fetch("/api/person.json").then(function (r) { return r.json(); }).then(function (a) {
        document.querySelectorAll("[data-pf]").forEach(function (e) {
          e.textContent = a[e.getAttribute("data-pf")];
        });
        var b = document.querySelector("[data-copy-person]");
        if (b) {
          b.setAttribute("data-address", a.name + ", " + a.gender + ", Age " + a.age + ", " + a.street + ", " + a.city + ", " + a.state + " " + a.zip + ", Phone: " + a.phone + ", Email: " + a.email + ", Username: " + a.username);
        }
      }).catch(function () {});
    }

    document.addEventListener("DOMContentLoaded", render);
    document.addEventListener("click", function (e) { if (e.target.closest("[data-regenerate]")) { render(); } });
    document.addEventListener("click", function (e) {
      var b = e.target.closest("[data-copy-person]");
      if (!b) return;
      var t = b.getAttribute("data-address") || "";
      navigator.clipboard.writeText(t).then(function () { showToast("Copied to clipboard!"); }).catch(function () {});
    });
  })();
  </script>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">About Random Person Generator</h2>
      <p class="text-gray-600 leading-relaxed mb-4">Our random person generator creates complete fictional profiles that include name, gender, age, street address, city, state, ZIP code, phone number, email address, and username. Each profile is internally consistent — the address components match, the phone area code corresponds to the state, and the email uses a real domain.</p>
      <p class="text-gray-600 leading-relaxed mb-4">Use these profiles for testing user registration flows, populating demo databases, load testing with realistic user data, and any scenario where you need complete fictional identities. All data is randomly generated and contains no real personal information.</p>
    </div>
    <div class="mt-12">
      <h3 class="text-xl font-semibold text-gray-900 mb-6 text-center">Related Tools</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <ToolCard href="/name-generator/" title="US Name Generator" description="Generate random first and last names for US residents." />
        <ToolCard href="/email-generator/" title="US Email Generator" description="Generate random US email addresses for testing." />
        <ToolCard href="/username-generator/" title="US Username Generator" description="Generate random usernames for testing and profiles." />
        <ToolCard href="/random-address-generator/" title="Random US Address Generator" description="Generate random US addresses with complete details." />
        <ToolCard href="/phone-number-generator/" title="US Phone Number Generator" description="Generate random US phone numbers with area codes." />
      </div>
    </div>
  </section>

  <FAQs faqs={faqs} />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getZipcodes } from '../../lib/generator';
import { buildTitle } from '../../lib/seo';

const allZips = getZipcodes();
---

<Layout title={buildTitle('All ZIP Codes - ZIP Code Address Generators')}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">ZIP Codes</h1>
    <p class="text-gray-600 mb-8">Select a ZIP code to generate random addresses for that ZIP code.</p>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {allZips.map(z => (
        <a href={`/zip-codes/${z.zip}/`} class="bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-sm transition">
          <span class="font-mono font-medium text-gray-900">{z.zip}</span>
          <span class="ml-2 text-sm text-gray-500">{z.city}, {z.state}</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

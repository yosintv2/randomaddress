---
import Layout from '../../layouts/Layout.astro';
import AddressCard from '../../components/AddressCard.astro';
import { generateAddressForZip, getZipcodes } from '../../lib/generator';
import { buildTitle, slugify } from '../../lib/seo';

export function getStaticPaths() {
  return getZipcodes().map(z => ({
    params: { zip: z.zip },
    props: { zipData: z },
  }));
}

const { zipData } = Astro.props;
const address = generateAddressForZip(zipData.zip);
const title = buildTitle(`Random Address ${zipData.zip} - ${zipData.city}, ${zipData.state} Address Generator`);
const description = `Generate random addresses for ZIP code ${zipData.zip} (${zipData.city}, ${zipData.state}). Free random address generator for ${zipData.zip}.`;
---

<Layout title={title} description={description}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Random Address {zipData.zip}</h1>
      <p class="text-gray-600">Generate random addresses for {zipData.zip} - {zipData.city}, {zipData.state}.</p>
    </div>

    <AddressCard {...address} />

    <div class="mt-8 text-center">
      <a href={Astro.url.pathname} class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition">
        Generate Another {zipData.zip} Address
      </a>
    </div>
  </section>
</Layout>

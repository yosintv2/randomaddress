---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { generateCompanyName } from '../lib/generator';
import { buildTitle, SITE_URL } from '../lib/seo';
const title = buildTitle('Company Name Generator - Random Company Names');
const description = 'Generate random company and business names for brainstorming and testing.';
const keywords = 'company name generator, business name generator, random company name, LLC name generator, fake company name';
const canonical = `${SITE_URL}/company-name-generator/`;

const companies = Array.from({ length: 10 }, () => generateCompanyName());
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'Company Name Generator', url: '/company-name-generator/' },
  ]} />
  <GeneratorTool
    title="Company Name Generator"
    description={description}
  >
    <div class="glass-card rounded-2xl p-6 sm:p-8 fade-in">
      <div class="space-y-2">
        {companies.map(c => (
          <div class="text-lg font-semibold text-gray-900 bg-gray-50 rounded-xl px-4 py-3">{c}</div>
        ))}
      </div>
    </div>
  </GeneratorTool>
</Layout>

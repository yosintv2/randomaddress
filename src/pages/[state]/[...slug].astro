---
import Layout from '../../layouts/Layout.astro';
import AddressCard from '../../components/AddressCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQs from '../../components/FAQs.astro';
import { getCities, getStates, getZipcodes, getCounties } from '../../lib/generator';
import { buildTitle, slugify, SITE_URL, getFAQSchema, getStateFAQs, getCityFAQs, getZipFAQs, getCountyFAQs, getStateContent, getCityContent, getZipContent, getCountyContent } from '../../lib/seo';

export function getStaticPaths() {
  const allStates = getStates();
  const allCities = getCities();
  const allZips = getZipcodes();
  const allCounties = getCounties();
  const seen = new Set<string>();
  const paths = [];

  for (const s of allStates) {
    const stateSlug = slugify(s.name);
    paths.push({ params: { state: stateSlug } });
    const stateCities = allCities.filter(c => c.state === s.name);
    for (const c of stateCities) {
      const key = `${stateSlug}/${slugify(c.city)}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { state: stateSlug, slug: slugify(c.city) } });
    }
    const stateZips = allZips.filter(z => z.state === s.name);
    for (const z of stateZips) {
      const key = `${stateSlug}/${z.zip}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { state: stateSlug, slug: z.zip } });
    }
    const stateCounties = allCounties.filter(c => c.state === s.name);
    for (const co of stateCounties) {
      const countySlug = slugify(co.name) + '-county';
      const key = `${stateSlug}/${countySlug}`;
      if (seen.has(key)) continue;
      seen.add(key);
      paths.push({ params: { state: stateSlug, slug: countySlug } });
    }
  }
  return paths;
}

const { state: stateSlug, slug } = Astro.params;

const allStates = getStates();
const state = allStates.find(s => slugify(s.name) === stateSlug);

if (!state) {
  Astro.redirect('/404');
  return;
}

const isZip = /^\d{5}$/.test(slug || '');
const isCounty = (slug || '').endsWith('-county');
let type: 'city' | 'zip' | 'county';
let cityName: string | undefined;
let zipData: { zip: string; city: string; state: string } | undefined;
let countyName: string | undefined;

if (isZip) {
  zipData = getZipcodes().find(z => z.zip === slug);
  type = zipData ? 'zip' : 'city';
  cityName = zipData ? zipData.city : '';
} else if (isCounty) {
  type = 'county';
  const countySlug = slug!.replace(/-county$/, '');
  const countyEntry = getCounties().find(c => slugify(c.name) === countySlug && c.state === state.name);
  countyName = countyEntry ? countyEntry.name : '';
} else {
  type = 'city';
  const cityEntry = getCities().find(c => slugify(c.city) === slug && c.state === state.name);
  cityName = cityEntry ? cityEntry.city : slug || '';
}

let title: string;
let description: string;
let heading: string;
let keywords: string;
let canonical: string;
let breadcrumbs: { name: string; url: string }[];
let placeSchema: Record<string, unknown>;

if (type === 'county') {
  const resolvedCounty = (countyName || slug!.replace(/-county$/, '')).replace(/\b\w/g, c => c.toUpperCase());
  title = buildTitle(`${resolvedCounty} County, ${state.name} Address Generator - Random ${resolvedCounty} Addresses`);
  description = `Generate random addresses for ${resolvedCounty} County, ${state.name}. Free random address generator with ZIP codes and phone numbers.`;
  heading = `${resolvedCounty} County, ${state.name} Address Generator`;
  keywords = `${resolvedCounty} County ${state.name} address, random ${resolvedCounty} County address, ${state.name} test data, ${resolvedCounty} County address generator, ${resolvedCounty} County fake address, free ${resolvedCounty} County address`;
  canonical = `${SITE_URL}/${stateSlug}/${slug}/`;
  breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: state.name, url: `/states/${stateSlug}/` },
    { name: `${resolvedCounty} County`, url: `/${stateSlug}/${slug}/` },
  ];
  placeSchema = {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: `${resolvedCounty} County, ${state.name} Address Generator`,
    description,
    address: { '@type': 'PostalAddress', addressRegion: state.name, addressCountry: 'US' },
  };
} else if (type === 'city') {
  const resolvedCity = cityName || '';
  title = buildTitle(`${resolvedCity}, ${state.name} Address Generator - Random ${resolvedCity} Addresses`);
  description = `Generate random addresses for ${resolvedCity}, ${state.name}. Free random address generator with ZIP codes and phone numbers.`;
  heading = `${resolvedCity}, ${state.name} Address Generator`;
  keywords = `${resolvedCity} ${state.name} address, random ${resolvedCity} address, ${state.name} test data, ${resolvedCity} address generator, ${resolvedCity} fake address, ${resolvedCity} ${state.name} ZIP, free ${resolvedCity} address, random ${resolvedCity} ${state.name}`;
  canonical = `${SITE_URL}/${stateSlug}/${slug}/`;
  breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: state.name, url: `/states/${stateSlug}/` },
    { name: resolvedCity, url: `/${stateSlug}/${slug}/` },
  ];
  placeSchema = {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: `${resolvedCity}, ${state.name} Address Generator`,
    description,
    address: { '@type': 'PostalAddress', addressLocality: resolvedCity, addressRegion: state.name, addressCountry: 'US' },
  };
} else if (zipData) {
  title = buildTitle(`Address ${zipData.zip}, ${zipData.state} - Random ${zipData.zip} Address`);
  description = `Generate random addresses for ZIP code ${zipData.zip} in ${zipData.state}. Free random address generator.`;
  heading = `Address ${zipData.zip}, ${zipData.state}`;
  keywords = `${zipData.zip} address, random ${zipData.zip} address, ZIP ${zipData.zip} ${zipData.state}, ${zipData.zip} fake address, ${zipData.zip} ${zipData.city}, random address ${zipData.zip}, free ${zipData.zip} address, ${zipData.zip} test data`;
  canonical = `${SITE_URL}/${stateSlug}/${zipData.zip}/`;
  breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: zipData.state, url: `/states/${stateSlug}/` },
    { name: `${zipData.zip} - ${zipData.city}`, url: `/${stateSlug}/${zipData.zip}/` },
  ];
  placeSchema = {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: `Address ${zipData.zip}`,
    description,
    address: { '@type': 'PostalAddress', postalCode: zipData.zip, addressLocality: zipData.city, addressRegion: zipData.state, addressCountry: 'US' },
  };
} else {
  title = buildTitle(`${state.name} Address Generator - Random ${state.name} Addresses`);
  description = `Generate random ${state.name} addresses with real cities, ZIP codes, and phone numbers.`;
  heading = `${state.name} Address Generator`;
  keywords = `${state.name} address generator, random ${state.name} address, ${state.name} ZIP codes, ${state.name} fake address, ${state.name} test data, ${state.name} street address, free ${state.name} address, ${state.name} random address`;
  canonical = `${SITE_URL}/${stateSlug}/`;
  breadcrumbs = [
    { name: 'Home', url: '/' },
    { name: state.name, url: `/states/${stateSlug}/` },
  ];
  placeSchema = {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: `${state.name} Address Generator`,
    description,
    address: { '@type': 'PostalAddress', addressRegion: state.name, addressCountry: 'US' },
  };
}

let faqs: { question: string; answer: string }[];
if (type === 'county') {
  faqs = getCountyFAQs(countyName || '', state.name);
} else if (type === 'city') {
  faqs = getCityFAQs(cityName || '', state.name);
} else if (zipData) {
  faqs = getZipFAQs(zipData.zip, zipData.city, zipData.state);
} else {
  faqs = getStateFAQs(state.name);
}

const cardState = zipData ? zipData.state : state.name;
const cardCity = type === 'city' ? cityName : '';
const cardZip = zipData ? zipData.zip : '';

let contentParagraphs: string[];
if (type === 'county') {
  contentParagraphs = getCountyContent(countyName || '', state.name);
} else if (type === 'city') {
  const cityZipCount = getZipcodes().filter(z => z.city === cityName).length;
  contentParagraphs = getCityContent(cityName || '', state.name, cityZipCount);
} else if (zipData) {
  contentParagraphs = getZipContent(zipData.zip, zipData.city, zipData.state);
} else {
  const stateCitiesList = getCities().filter(c => c.state === state.name).map(c => c.city);
  contentParagraphs = getStateContent(state.name, [...new Set(stateCitiesList)]);
}
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <Breadcrumbs items={breadcrumbs} />

  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(placeSchema)} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">{heading}</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{description}</p>
    </div>

    <AddressCard state={cardState} city={cardCity} zip={cardZip} />
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto space-y-4 text-gray-600 leading-relaxed">
      {contentParagraphs.map(p => <p>{p}</p>)}
    </div>
  </section>

  <FAQs faqs={faqs} />
</Layout>

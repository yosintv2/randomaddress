---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import AddressCard from '../components/AddressCard.astro';
import { buildTitle } from '../lib/seo';
---

<Layout title={buildTitle('Random Address Generator - Random US Addresses')}>
  <GeneratorTool
    title="Random Address Generator"
    description="Generate random US addresses instantly. Get complete addresses with street, city, state, ZIP code, and phone number."
  >
    <AddressCard />
  </GeneratorTool>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import AddressCard from '../components/AddressCard.astro';
import { buildTitle } from '../lib/seo';
---

<Layout title={buildTitle('Random City Generator - Random City Addresses')}>
  <GeneratorTool
    title="Random City Generator"
    description="Generate random US addresses from random cities across all 50 states."
  >
    <AddressCard />
  </GeneratorTool>
</Layout>

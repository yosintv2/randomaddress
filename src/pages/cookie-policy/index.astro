---
import Layout from '../../layouts/Layout.astro';
import { buildTitle } from '../../lib/seo';
---

<Layout title={buildTitle('Cookie Policy')}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 prose prose-gray">
    <h1>Cookie Policy</h1>
    <p>Last updated: January 2025</p>
    <h2>What Are Cookies</h2>
    <p>Cookies are small text files stored on your device when you visit a website.</p>
    <h2>How We Use Cookies</h2>
    <p>We use cookies for:</p>
    <ul>
      <li>Google AdSense - to serve relevant advertisements</li>
      <li>Cloudflare Analytics - to understand website usage</li>
    </ul>
    <h2>Managing Cookies</h2>
    <p>You can control and delete cookies through your browser settings. Note that disabling cookies may affect the functionality of certain features.</p>
  </article>
</Layout>

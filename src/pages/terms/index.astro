---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { buildTitle, SITE_URL, getWebPageSchema } from '../../lib/seo';
const description = 'Terms of service for Random US Address Generator. Please read these terms carefully before using our service.';
const canonical = `${SITE_URL}/terms/`;
---

<Layout title={buildTitle('Terms of Service')} description={description} canonical={canonical}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getWebPageSchema(buildTitle('Terms of Service'), description, canonical))} />
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'Terms of Service', url: '/terms/' },
  ]} />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 prose prose-gray">
    <h1>Terms of Service</h1>
    <p>Last updated: June 2026</p>
    <h2>Acceptance of Terms</h2>
    <p>By using RandomUSAddress.com, you agree to these terms of service.</p>
    <h2>Use of Service</h2>
    <p>Our service generates random addresses for testing and educational purposes. You agree not to use these addresses for:</p>
    <ul>
      <li>Fraudulent activities</li>
      <li>Identity theft</li>
      <li>Shipping or purchasing goods</li>
      <li>Legal documentation</li>
      <li>Any illegal purpose</li>
    </ul>
    <h2>Disclaimer</h2>
    <p>All addresses generated are fictional. We make no guarantees about accuracy or suitability for any purpose.</p>
    <h2>Changes</h2>
    <p>We reserve the right to modify these terms at any time.</p>
  </article>
</Layout>

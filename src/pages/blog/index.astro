---
import Layout from '../../layouts/Layout.astro';
import { buildTitle } from '../../lib/seo';
import { articles } from '../../lib/blog';
---

<Layout title={buildTitle('Blog - Random US Address Generator')}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Blog</h1>
    <p class="text-gray-600 mb-8">Articles about random address generation, testing data, and more.</p>
    <div class="space-y-6">
      {articles.map(a => (
        <article class="bg-white rounded-lg border border-gray-200 p-6">
          <time class="text-sm text-gray-500">{a.date}</time>
          <h2 class="text-xl font-semibold mt-1">
            <a href={`/blog/${a.slug}/`} class="text-gray-900 hover:text-blue-600">{a.title}</a>
          </h2>
        </article>
      ))}
    </div>
  </section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getStates } from '../../lib/generator';
import { buildTitle, slugify } from '../../lib/seo';

const allStates = getStates();
---

<Layout title={buildTitle('All US States - State Address Generators')}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">US States</h1>
    <p class="text-gray-600 mb-8">Select a state to generate random addresses for that state.</p>
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {allStates.map(s => (
        <a href={`/states/${slugify(s.name)}/`} class="bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-300 hover:shadow-sm transition">
          <span class="font-medium text-gray-900">{s.name}</span>
          <span class="ml-2 text-sm text-gray-500">({s.abbr})</span>
        </a>
      ))}
    </div>
  </section>
</Layout>

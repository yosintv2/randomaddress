---
import Layout from '../../layouts/Layout.astro';
import AddressCard from '../../components/AddressCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQs from '../../components/FAQs.astro';
import { getStates, getCities } from '../../lib/generator';
import { buildTitle, slugify, SITE_URL, getFAQSchema, getStateFAQs, getStateContent } from '../../lib/seo';

export function getStaticPaths() {
  return getStates().map(s => ({
    params: { state: slugify(s.name) },
    props: { stateData: s },
  }));
}

const { state: stateSlug } = Astro.params;
const state = Astro.props.stateData;

if (!state) {
  Astro.redirect('/404');
  return;
}

const stateCities = getCities().filter(c => c.state === state.name).slice(0, 12);
const title = buildTitle(`${state.name} Address Generator - Random ${state.name} Addresses`);
const description = `Generate random ${state.name} addresses with real cities, ZIP codes, and phone numbers. Free ${state.name} random address generator for testing.`;
const keywords = `${state.name} address generator, random ${state.name} address, ${state.name} ZIP codes, ${state.abbr} address generator, free ${state.name} test data, ${state.name} fake address, ${state.name} random address, ${state.name} address, ${state.name} street address, ${state.name} test address`;
const faqs = getStateFAQs(state.name);
const canonical = `${SITE_URL}/states/${stateSlug}/`;
const stateCitiesList = getCities().filter(c => c.state === state.name).map(c => c.city);
const stateContent = getStateContent(state.name, [...new Set(stateCitiesList)]);
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: state.name, url: `/states/${stateSlug}/` },
  ]} />

  <script slot="schema" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: `${state.name} Address Generator`,
    description,
    address: { '@type': 'PostalAddress', addressRegion: state.abbr, addressCountry: 'US' },
  })} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-3">{state.name} Address Generator</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">Generate random addresses for {state.name} ({state.abbr}). Including cities, ZIP codes, and phone numbers.</p>
    </div>

    <AddressCard state={state.name} />

    {stateCities.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Cities in {state.name}</h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
          {stateCities.map(c => (
            <a href={`/${stateSlug}/${slugify(c.city)}/`} class="glass-card rounded-xl px-4 py-3 text-sm font-medium text-gray-700 hover:text-brand-600 card-hover text-center">
              {c.city}
            </a>
          ))}
        </div>
        <div class="text-center mt-6">
          <a href={`/${stateSlug}/`} class="text-brand-600 hover:text-brand-700 text-sm font-medium">View all {state.name} addresses</a>
        </div>
      </section>
    )}
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto space-y-4 text-gray-600 leading-relaxed">
      {stateContent.map(p => <p>{p}</p>)}
    </div>
  </section>

  <FAQs faqs={faqs} />
</Layout>

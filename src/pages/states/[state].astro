---
import Layout from '../../layouts/Layout.astro';
import AddressCard from '../../components/AddressCard.astro';
import { getStates } from '../../lib/generator';
import { buildTitle, slugify } from '../../lib/seo';

export function getStaticPaths() {
  return getStates().map(s => ({
    params: { state: slugify(s.name) },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const title = buildTitle(`${state.name} Address Generator - Random ${state.name} Addresses`);
const description = `Generate random ${state.name} addresses with real cities, ZIP codes, and phone numbers. Free ${state.name} random address generator for testing.`;
---

<Layout title={title} description={description}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">{state.name} Address Generator</h1>
      <p class="text-gray-600">Generate random addresses for {state.name} ({state.abbr}). Including cities, ZIP codes, and phone numbers.</p>
    </div>

    <AddressCard />

    <div class="mt-8 text-center">
      <a href={Astro.url.pathname} class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition">
        Generate Another {state.name} Address
      </a>
    </div>
  </section>
</Layout>

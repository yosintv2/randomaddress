---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import AddressCard from '../components/AddressCard.astro';
import { generateAddress } from '../lib/generator';
import { buildTitle } from '../lib/seo';

const address = generateAddress();
---

<Layout title={buildTitle('Random State Generator - Random US State Addresses')}>
  <GeneratorTool
    title="Random State Generator"
    description="Generate random US addresses from any state. Each click generates an address from a different state."
  >
    <AddressCard {...address} />
  </GeneratorTool>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import ToolCard from '../components/ToolCard.astro';
import FAQs from '../components/FAQs.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { buildTitle, SITE_URL, getFAQSchema, getWebPageSchema } from '../lib/seo';
const title = buildTitle('US IP Address Generator - Random US IP Addresses');
const description = 'Generate random US IP addresses for testing and development.';
const keywords = 'IP generator, random IP address, US IP, IP address generator, test IP, IPv4 address, network test data, US IP range, random IP, fake IP address';
const canonical = `${SITE_URL}/ip-address-generator/`;
const faqs = [
  { question: 'What is an IP address generator?', answer: 'An IP address generator creates random IPv4 addresses for testing and development purposes.' },
  { question: 'Are these real IP addresses?', answer: 'These are randomly generated IP addresses using common US IP prefixes. They are not connected to any real device or network.' },
  { question: 'What IP versions are generated?', answer: 'The generator produces IPv4 addresses with realistic US-based prefixes.' },
  { question: 'Can I use these for testing?', answer: 'Yes, these IP addresses are perfect for testing network applications, security tools, and populating databases.' },
  { question: 'How many IPs are generated at once?', answer: 'The generator produces 20 IP addresses at a time with a single click.' },
  { question: 'Is this tool free?', answer: 'Yes, our IP address generator is completely free to use with no registration required.' },
];
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getWebPageSchema(title, description, canonical))} />
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(getFAQSchema(faqs))} />
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'US IP Address Generator', url: '/ip-address-generator/' },
  ]} />
  <GeneratorTool
    title="US IP Address Generator"
    description={description}
  >
    <div class="glass-card rounded-2xl p-6 sm:p-8 fade-in">
      <div class="space-y-2" id="ip-list"></div>
    </div>
  </GeneratorTool>
  <div class="flex justify-center mb-3">
    <button id="copy-all-ips" class="btn-secondary text-sm px-4 py-2 w-full sm:w-auto min-h-[44px]">
      <svg class="w-4 h-4 inline-block mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/>
      </svg>
      Copy All
    </button>
  </div>
  <script is:inline>
  (function () {
    function showToast(msg) {
      var d = document.getElementById("toast");
      if (!d) {
        d = document.createElement("div");
        d.id = "toast";
        d.className = "fixed bottom-24 left-1/2 -translate-x-1/2 z-50 bg-gray-900 text-white text-sm font-medium px-5 py-3 rounded-xl shadow-2xl animate-slide-up";
        document.body.appendChild(d);
      }
      d.textContent = msg;
      d.style.animation = "slideUp 0.3s ease-out";
      setTimeout(function () {
        d.style.animation = "toastOut 0.3s ease-out forwards";
        setTimeout(function () { if (d && d.parentNode) d.parentNode.removeChild(d); }, 300);
      }, 2000);
    }
    function render() {
      fetch("/api/ips.json?count=20").then(function (r) { return r.json(); }).then(function (ips) {
        var c = document.getElementById("ip-list");
        if (!c) return;
        c.innerHTML = "";
        ips.forEach(function (ip, i) {
          var w = document.createElement("div");
          w.className = "flex items-center gap-2 group flex-col sm:flex-row";
          var d = document.createElement("div");
          d.className = "flex-1 font-mono text-sm text-gray-900 dark:text-gray-100 bg-gray-50 dark:bg-slate-700 rounded-xl px-4 py-2.5 truncate w-full sm:w-auto";
          d.textContent = ip;
          var btn = document.createElement("button");
          btn.className = "shrink-0 p-2.5 rounded-lg bg-gray-100 dark:bg-slate-600 hover:bg-gray-200 dark:hover:bg-slate-500 text-gray-500 dark:text-gray-300 transition-colors min-h-[44px] min-w-[44px]";
          btn.setAttribute("aria-label", "Copy " + ip);
          btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>';
          btn.addEventListener("click", function () {
            navigator.clipboard.writeText(ip).then(function () { showToast("Copied " + ip); }).catch(function () {});
          });
          w.appendChild(d);
          w.appendChild(btn);
          c.appendChild(w);
        });
      }).catch(function () {});
    }
    document.addEventListener("DOMContentLoaded", render);
    document.addEventListener("click", function (e) { if (e.target.closest("[data-regenerate]")) { render(); } });
    document.getElementById("copy-all-ips")?.addEventListener("click", function () {
      var items = document.querySelectorAll("#ip-list .font-mono");
      var text = Array.from(items).map(function (el) { return el.textContent; }).join("\n");
      if (!text) return;
      navigator.clipboard.writeText(text).then(function () { showToast("Copied all IPs!"); }).catch(function () {});
    });
  })();
  </script>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">About US IP Address Generator</h2>
      <p class="text-gray-600 leading-relaxed mb-4">Our US IP address generator creates 20 random IPv4 addresses using realistic US-based IP prefixes. Each address follows the standard IPv4 format with octets ranging from common US-assigned blocks.</p>
      <p class="text-gray-600 leading-relaxed mb-4">Perfect for testing network applications, security tools, log simulation, database population, and any development scenario that requires realistic US IP addresses.</p>
    </div>
    <div class="mt-12">
      <h3 class="text-xl font-semibold text-gray-900 mb-6 text-center">Related Tools</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <ToolCard href="/random-us-address/" title="US Address Generator" description="Generate random US addresses for testing and development." />
        <ToolCard href="/random-person-generator/" title="US Person Generator" description="Generate complete US person profiles with address, phone, and email." />
        <ToolCard href="/phone-number-generator/" title="US Phone Number Generator" description="Generate random US phone numbers by state." />
      </div>
    </div>
  </section>

  <FAQs faqs={faqs} />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import AddressCard from '../../components/AddressCard.astro';
import { getCities } from '../../lib/generator';
import { buildTitle, slugify } from '../../lib/seo';

export function getStaticPaths() {
  const seen = new Set<string>();
  return getCities().filter(c => {
    const key = slugify(c.city);
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  }).map(c => ({
    params: { city: slugify(c.city) },
    props: { cityData: c },
  }));
}

const { cityData } = Astro.props;
const title = buildTitle(`${cityData.city} Address Generator - Random ${cityData.city} Addresses`);
const description = `Generate random ${cityData.city}, ${cityData.state} addresses. Free ${cityData.city} random address generator with ZIP codes and phone numbers.`;
---

<Layout title={title} description={description}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-3">{cityData.city} Address Generator</h1>
      <p class="text-gray-600">Generate random addresses for {cityData.city}, {cityData.state}. Including streets, ZIP codes, and phone numbers.</p>
    </div>

    <AddressCard />

    <div class="mt-8 text-center">
      <a href={Astro.url.pathname} class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition">
        Generate Another {cityData.city} Address
      </a>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import GeneratorTool from '../components/GeneratorTool.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import firstNames from '../data/firstNames.json';
import lastNames from '../data/lastNames.json';
import { buildTitle, SITE_URL } from '../lib/seo';
const title = buildTitle('Name Generator - Random Names');
const description = 'Generate random first and last names for US residents. Perfect for testing and development.';
const keywords = 'name generator, random name generator, random names, US name generator, test names';
const canonical = `${SITE_URL}/name-generator/`;

const dataJson = JSON.stringify({ firstNames, lastNames });
const script = `(function(){
var D=${dataJson};
function p(a){return a[Math.floor(Math.random()*a.length)]}
function gen(n){var r=[];for(var i=0;i<n;i++){var fn=p(D.firstNames),ln=p(D.lastNames);r.push({name:fn+" "+ln,gender:Math.random()>0.5?"Male":"Female"})}return r}
function render(){var names=gen(10);var c=document.getElementById("name-list");if(!c)return;c.innerHTML="";names.forEach(function(n){var d=document.createElement("div");d.className="flex items-center justify-between bg-gray-50 dark:bg-slate-700 rounded-xl px-4 py-2.5";d.innerHTML='<span class="font-medium text-gray-900 dark:text-gray-100">'+n.name+'</span><span class="text-xs text-gray-400 bg-white dark:bg-slate-600 px-2 py-1 rounded">'+n.gender+'</span>';c.appendChild(d)})}
document.addEventListener("DOMContentLoaded",render);
document.addEventListener("click",function(e){if(e.target.closest("[data-regenerate]")){render()}});
})();`;
---

<Layout title={title} description={description} keywords={keywords} canonical={canonical}>
  <Breadcrumbs items={[
    { name: 'Home', url: '/' },
    { name: 'Name Generator', url: '/name-generator/' },
  ]} />
  <GeneratorTool
    title="Name Generator"
    description={description}
  >
    <div class="glass-card rounded-2xl p-6 sm:p-8 fade-in">
      <div class="space-y-2" id="name-list">
      </div>
    </div>
  </GeneratorTool>
  <script is:inline set:html={script} />
</Layout>